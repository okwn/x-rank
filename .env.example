# X API v2 bearer token with pay-per-use/read access for user lookup,
# recent search, and post lookup. Paste the bearer (starts with `AAAA…`),
# NOT an xAI Grok key (`xai-…`). Current pricing lives in console.x.com.
X_BEARER_TOKEN=

# Optional: API server port (default 3000)
# PORT=3000

# Optional: SQLite DB path (default ./data/snapshots.db)
# X_RANK_DB=./data/snapshots.db

# Optional: cached snapshot TTL for the live API server (default: 1 hour).
# If ENABLE_REFRESH_DAEMON=true, this also controls the daemon cadence.
# Accepts Effect durations like "15 minutes", "1 hour", or "500 millis".
# REFRESH_INTERVAL=1 hour

# Optional: make `bun run server` refresh forever in the background.
# Leave this off for static self-hosting; prefer explicit CLI refreshes.
# ENABLE_REFRESH_DAEMON=false
